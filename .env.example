# Copy to `.env` in the project root and change values if needed.
# Docker Compose loads `.env` automatically for variable substitution.

POSTGRES_USER=phoneuser
POSTGRES_PASSWORD=phonepass
POSTGRES_DB=phonenumbers
POSTGRES_PORT=5432

API_PORT=8080

# Go app on host → Postgres in Docker (localhost port = POSTGRES_PORT)
DATABASE_URL=postgres://phoneuser:phonepass@localhost:5432/phonenumbers?sslmode=disable
